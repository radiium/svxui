{
    "name": "docs",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "predev": "npm run gen:libdocjson",
        "prebuild": "npm run gen:libdocjson",
        "precheck": "npm run gen:libdocjson",
        "gen:libdocjson": "node ./scripts/generate-api.mjs"
    },
    "dependencies": {
        "phosphor-svelte": "^3.1.0",
        "svxui": "workspace:*"
    },
    "devDependencies": {
        "@shikijs/transformers": "^4.0.2",
        "@sveltejs/adapter-vercel": "^6.3.3",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^22",
        "mdsvex": "^0.12.7",
        "rehype-slug": "^6.0.0",
        "shiki": "^4.0.2",
        "svelte": "^5.55.0",
        "svelte-check": "^4.4.5",
        "svelte-preprocess": "^6.0.3",
        "svxui-docgen": "workspace:*",
        "typescript": "^5.9.3",
        "vite": "^8.0.3",
        "vite-plugin-devtools-json": "^1.0.0"
    }
}
