{
    "name": "root",
    "private": true,
    "version": "0.0.0",
    "description": "Monorepo of Svxui library",
    "homepage": "https://github.com/radiium/svxui",
    "license": "MIT",
    "author": {
        "name": "radiium",
        "url": "https://github.com/radiium"
    },
    "keywords": [
        "svelte",
        "sveltekit",
        "ui",
        "library",
        "ui-components",
        "components",
        "components-library",
        "open-source",
        "typescript",
        "web",
        "monorepo"
    ],
    "bugs": {
        "url": "https://github.com/radiium/svxui/issues"
    },
    "main": "index.js",
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "pnpm run build:*",
        "build:packages": "pnpm --filter=./packages/** --parallel build",
        "build:docs": "pnpm --filter docs -r build",
        "check": "pnpm -r check",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "-- VERCEL": "",
        "vercel:prepare": "pnpm run build:packages",
        "vercel:build": "pnpm run build:docs"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^9.39.4",
        "cz-git": "^1.13.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "prettier": "latest",
        "prettier-plugin-svelte": "^3.5.1",
        "typescript-eslint": "^8.59.2"
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-git"
        }
    }
}
