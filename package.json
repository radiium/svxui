{
    "name": "root",
    "private": true,
    "version": "0.0.0",
    "description": "Monorepo of Svxui library",
    "homepage": "https://github.com/radiium/svxui",
    "license": "MIT",
    "author": {
        "name": "radiium",
        "url": "https://github.com/radiium"
    },
    "keywords": [
        "svelte",
        "sveltekit",
        "ui",
        "library",
        "ui-components",
        "components",
        "components-library",
        "open-source",
        "typescript",
        "web",
        "monorepo"
    ],
    "bugs": {
        "url": "https://github.com/radiium/svxui/issues"
    },
    "main": "index.js",
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "pnpm run build:*",
        "build:packages": "pnpm --filter=./packages/** --parallel build",
        "build:docs": "pnpm --filter docs -r build",
        "check": "pnpm -r check",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "-- VERCEL": "",
        "vercel:prepare": "pnpm run build:packages",
        "vercel:build": "pnpm run build:docs"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^9.39.4",
        "cz-git": "^1.12.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-svelte": "^3.16.0",
        "globals": "^17.4.0",
        "prettier": "latest",
        "prettier-plugin-svelte": "^3.5.1",
        "typescript-eslint": "^8.57.2"
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-git"
        }
    }
}
