        "package:watch": "svelte-kit sync && svelte-package --watch",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "test:unit": "vitest",
        "test:client": "vitest --project=client",
        "test:server": "vitest --project=server",
        "predev": "npm run gen:styles && npm run gen:exports",
        "prebuild": "npm run gen:styles && npm run gen:exports",
        "prepackage": "npm run gen:styles && npm run gen:exports",
        "precheck": "npm run gen:styles && npm run gen:exports",
        "gen:styles": "node ./scripts/generate-styles.mjs",
        "gen:exports": "node ./scripts/generate-exports.mjs"
