{
    "name": "svxui-docgen",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "check": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^22",
        "shiki": "^4.0.2",
        "svelte": "^5.54.1",
        "ts-morph": "^27.0.2",
        "typescript": "~5.9.3"
    }
}
